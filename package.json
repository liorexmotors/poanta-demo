{
  "name": "poanta-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "vite --host 0.0.0.0",
    "build": "rm -rf dist && mkdir -p dist && cp index.html studio.html feedback-dashboard.html topic-badges-preview.html feed.json breaking_feed.json candidates.json rss_sources.json breaking_sources.json sw.js manifest.webmanifest icon-192.png icon-512.png favicon-32.png favicon.ico .nojekyll dist/ && cp -R assets dist/",
    "quality": "python3 scripts/pointa_quality_gate.py --report pointa_quality_report.md",
    "editor:prepare": "python3 scripts/pointa_editor_pipeline.py prepare",
    "editor:prepare:fast": "python3 scripts/pointa_editor_pipeline.py prepare --sync-profile fast --limit 18 --batch-size 6 --max-per-category 6",
    "editor:prepare:medium": "python3 scripts/pointa_editor_pipeline.py prepare --sync-profile medium --limit 18 --batch-size 6 --max-per-category 6",
    "editor:prepare:slow": "python3 scripts/pointa_editor_pipeline.py prepare --sync-profile slow --limit 16 --batch-size 8 --max-per-category 5",
    "editor:qa": "python3 scripts/pointa_editor_pipeline.py qa",
    "editor:apply": "python3 scripts/pointa_editor_pipeline.py apply",
    "sync:fast": "python3 scripts/update_feed.py --sync-profile fast",
    "sync:breaking": "python3 scripts/update_breaking_feed.py",
    "sync:medium": "python3 scripts/update_feed.py --sync-profile medium",
    "sync:slow": "python3 scripts/update_feed.py --sync-profile slow",
    "engagement": "python3 scripts/editor_engagement_score.py"
  },
  "devDependencies": {}
}
